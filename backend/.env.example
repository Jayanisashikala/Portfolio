# Port the API listens on
PORT=4000

# Comma-separated list of origins allowed to call this API.
# For GitHub Pages, this looks like: https://<your-username>.github.io
CORS_ORIGIN=http://localhost:5500,https://<your-username>.github.io

# ── Email delivery for the contact form (optional) ──────────────
# If these are left blank, submissions are still saved to
# backend/data/messages.json so nothing is lost.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_TO=jayanisashikala38@gmail.com
